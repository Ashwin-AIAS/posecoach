# PoseCoach Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Database ===
POSTGRES_URL=postgresql+asyncpg://posecoach:password@localhost:5432/posecoach
# TLS for managed Postgres (asyncpg ignores sslmode in the URL — SQLAlchemy
# hands it discrete params, so TLS must go via connect_args). libpq-style
# values: require, verify-ca, verify-full. Leave unset for local/dev Postgres.
# POSTGRES_SSL=require

# === Cache ===
REDIS_URL=redis://localhost:6379/0

# === AI / LLM ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash  # Override if Google retires the model (e.g. gemini-2.0-flash was shut down 2026-06-01)
OPENROUTER_API_KEY=your_openrouter_api_key_here  # Used for Qwen 3.6 (P05 chatbot + P10 VLM judge)
# Live web-search fallback for the chatbot when local RAG can't confidently
# answer (P14). Tavily by default; leave blank to disable (chat still works,
# answering from general knowledge). Optional WEB_SEARCH_URL overrides the provider.
WEB_SEARCH_API_KEY=
# WEB_SEARCH_URL=https://api.tavily.com/search

# === Auth ===
JWT_SECRET=change_me_to_a_random_64_char_string

# === YOLO Model ===
MODEL_PATH=models/yolo26n-pose.pt

# Per-keypoint confidence gate for joint-angle computation (app/analysis).
# Joints whose keypoints fall below this are not measured. Lowered from the old
# 0.50 because real webcam keypoints land in the 0.10–0.50 band (P11 finding).
# 0.25 is the interim default; replace with the measured percentile after an
# in-gym capture session (see docs/p11_calibration_session.md).
ANGLE_CONF_THRESHOLD=0.25

# === ChromaDB ===
CHROMA_PATH=data/chroma

# === Nutrition (P27) ===
# Open Food Facts asks for a descriptive User-Agent with a contact address on
# every read. Set your contact email in production, e.g.
# "PoseCoach/1.0 (you@example.com)". Reads are keyless; lookups are cached in
# the food_items table so repeat scans never hit the API.
OFF_USER_AGENT=PoseCoach/1.0 (thesis project)

# === CORS ===
# Comma-separated. Add the Vercel domain in prod, e.g.
# ALLOWED_ORIGINS=https://posecoach.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Auth cookie SameSite policy (P29). "lax" works when frontend and backend
# share a site; a Vercel frontend + separate HF Space backend is cross-origin,
# so prod needs "none" — which browsers only honor when Secure is also set,
# i.e. ENVIRONMENT != development. Leave unset for local dev.
# COOKIE_SAMESITE=none
COOKIE_SAMESITE=lax

# === Environment ===
ENVIRONMENT=development

# === Optional: Sentry ===
# SENTRY_DSN=

# === Optional: Prometheus ===
# METRICS_TOKEN=
