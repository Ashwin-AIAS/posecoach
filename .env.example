# PoseCoach Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Database ===
POSTGRES_URL=postgresql+asyncpg://posecoach:password@localhost:5432/posecoach

# === Cache ===
REDIS_URL=redis://localhost:6379/0

# === AI / LLM ===
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here  # Used for Qwen 3.6 (P05 chatbot + P10 VLM judge)

# === Auth ===
JWT_SECRET=change_me_to_a_random_64_char_string

# === YOLO Model ===
MODEL_PATH=models/yolo26n-pose.pt

# === ChromaDB ===
CHROMA_PATH=data/chroma

# === CORS ===
ALLOWED_ORIGINS=http://localhost:5173

# === Environment ===
ENVIRONMENT=development

# === Optional: Sentry ===
# SENTRY_DSN=

# === Optional: Prometheus ===
# METRICS_TOKEN=
